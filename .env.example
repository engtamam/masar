# ═══════════════════════════════════════════════════════════════
# Masar Platform - Environment Variables Template
# Copy this file to .env and update values for your environment
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────

# Database URL
# SQLite (dev):   file:./dev.db
# SQLite (prod):  file:/app/db/production.db
# PostgreSQL:     postgresql://user:password@localhost:5432/masar
DATABASE_URL=file:./dev.db

# JWT Secret - CHANGE IN PRODUCTION!
# Generate with: make gen-keys
JWT_SECRET=change-me-in-production

# ─── Admin Account ────────────────────────────────────────
# Change these BEFORE running `make setup`
# This is the only auto-created account — other users register themselves
ADMIN_EMAIL=admin@masar.sa
ADMIN_PASSWORD=admin123
ADMIN_NAME=مدير المنصة

# ─── Domain & Auth ────────────────────────────────────────
# Required for Caddy, email links, and production
# DOMAIN=masar.example.com

# Base URL for the platform (used in email links)
# NEXTAUTH_URL=https://masar.example.com

# ─── Email Service ────────────────────────────────────────
# Sign up at https://resend.com and add your API key
# Without this, emails print to console (development mode)
# RESEND_API_KEY=re_your_key_here
# EMAIL_FROM=noreply@yourdomain.com

# ─── Platform Configuration ───────────────────────────────
# These can be overridden later from the Admin Control Panel

# PLATFORM_NAME=مَسَار
# DEFAULT_MONTHLY_QUOTA=4
# DEFAULT_SLOT_DURATION=30

# AES-256 encryption key for file storage - CHANGE IN PRODUCTION!
# Generate with: make gen-keys
# ENCRYPTION_KEY=default-encryption-key-change-me

# UPLOAD_MAX_SIZE_MB=10
# ALLOWED_FILE_TYPES=["pdf","doc","docx","xls","xlsx","ppt","pptx","jpg","jpeg","png","zip"]
# DEFAULT_LANGUAGE=ar
# JWT_EXPIRY=7d
